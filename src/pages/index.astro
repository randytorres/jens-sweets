---
import Base from '../layouts/Base.astro';
import { Image } from 'astro:assets';
import conchaHero from '../assets/concha-hero.png';
import handsPhoto from '../assets/hands.png';
import boxPhoto from '../assets/box-photo.png';

const menuItems = [
  { name: 'Vanilla Concha', price: '$4.50' },
  { name: 'Chocolate Concha', price: '$4.50' },
  { name: 'Strawberry Concha', price: '$4.50' },
  { name: 'Marranito', price: '$3.75' },
  { name: 'Polvorones', price: '$2.50' },
  { name: 'Cuerno', price: '$4.50' },
  { name: 'Oreja', price: '$3.50' },
  { name: 'Empanada Dulce', price: '$4.00' },
];

const boxes = [
  { name: 'The Morning Mix', pieces: '6 pieces', price: '$24' },
  { name: 'The Team Sweet', pieces: '12 pieces', price: '$45' },
  { name: 'The Big Concha Box', pieces: '24 pieces', price: '$85' },
];
---

<Base
  title="Jen's Sweets — Mexican Pastry for Boston Offices"
  description="Fresh conchas, marranitos, and pan dulce baked at 4am and delivered to your Boston office by 9. Order a sample box today."
>

<nav>
  <a href="/" class="nav-logo" aria-label="Jen's Sweets home">
    <div class="monogram"><span>JS</span></div>
  </a>
  <div class="nav-links">
    <a href="#menu">Menu</a>
    <a href="#story">Story</a>
    <a href="/order">Order</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <p class="overline">Mexican pastry for Boston offices</p>

  <div class="hero-image">
    <Image
      src={conchaHero}
      alt="A pink concha, freshly baked"
      width={560}
      height={560}
      loading="eager"
      class="concha-img"
    />
  </div>

  <h1>Baked at four. Delivered by nine.</h1>

  <div class="hero-cta">
    <div class="cta-line"></div>
    <a href="/order">Place an order</a>
  </div>
</section>

<!-- MENU -->
<section class="menu" id="menu">
  <h2>Menu</h2>
  <ul class="menu-list" role="list">
    {menuItems.map((item) => (
      <li class="menu-item">
        <span class="menu-name">{item.name}</span>
        <span class="menu-price">{item.price}</span>
      </li>
    ))}
  </ul>
</section>

<!-- STORY PHOTO -->
<section class="story-photo" id="story">
  <div class="story-image">
    <Image
      src={handsPhoto}
      alt="Hands pressing a shell pattern into concha dough"
      width={720}
      height={560}
      class="hands-img"
    />
  </div>
</section>

<!-- BOX PHOTO -->
<section class="box-photo">
  <div class="box-image">
    <Image
      src={boxPhoto}
      alt="A kraft box of conchas with a card reading para ti"
      width={720}
      height={480}
      class="box-img"
    />
  </div>
</section>

<!-- BOXES -->
<section class="boxes" id="boxes">
  <h2>Box</h2>
  <div class="box-grid">
    {boxes.map((box) => (
      <a href="/order" class="box-card">
        <span class="box-name">{box.name}</span>
        <span class="box-meta">{box.pieces}, {box.price}</span>
      </a>
    ))}
  </div>
</section>

<!-- ORDER / CONTACT -->
<section class="contact" id="order">
  <p class="overline">Ready?</p>
  <h2>Tell us when and where.</h2>
  <p class="contact-body">
    We deliver fresh pan dulce to offices in Boston, Monday through Friday.
    Orders close 48 hours before delivery. First box is on us.
  </p>
  <div class="contact-actions">
    <a href="/order" class="contact-btn">Place an order</a>
    <a href="mailto:hello@jenssweets.com" class="contact-link">or email us</a>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="monogram monogram-sm"><span>JS</span></div>
  <p>&copy; {new Date().getFullYear()} Jen's Sweets &nbsp;&middot;&nbsp; <a href="/terms" class="footer-link">Terms</a></p>
</footer>

</Base>

<style>
  /* ===== NAV ===== */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2.5rem;
    background: rgba(245, 242, 236, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .monogram {
    width: 44px;
    height: 44px;
    border: 1.25px solid var(--ink);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .monogram span {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  .monogram-sm {
    width: 36px;
    height: 36px;
    border-width: 1px;
  }

  .monogram-sm span {
    font-size: 0.8rem;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
  }

  .nav-links a {
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.04em;
    color: var(--ink-light);
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--ink);
  }

  /* ===== HERO ===== */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 8rem 2rem 4rem;
  }

  .overline {
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 400;
    margin-bottom: var(--space-xl);
  }

  .hero-image {
    width: 280px;
    height: 280px;
    margin-bottom: var(--space-xl);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .concha-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.1));
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1.25;
    color: var(--ink);
    max-width: 540px;
    margin-bottom: var(--space-lg);
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .cta-line {
    width: 60px;
    height: 1px;
    background: var(--terracotta);
  }

  .hero-cta a {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--ink);
    border-bottom: 1px solid var(--ink);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .hero-cta a:hover {
    color: var(--terracotta);
    border-color: var(--terracotta);
  }

  /* ===== MENU ===== */
  .menu {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 2.5rem var(--space-2xl);
  }

  .menu h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .menu-list {
    list-style: none;
  }

  .menu-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--rule-light);
  }

  .menu-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 400;
  }

  .menu-price {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--ink-muted);
  }

  /* ===== STORY PHOTO ===== */
  .story-photo {
    display: flex;
    justify-content: center;
    padding: var(--space-xl) 2.5rem var(--space-2xl);
  }

  .story-image {
    width: 360px;
    border-radius: 8px;
    overflow: hidden;
  }

  .hands-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===== BOX PHOTO ===== */
  .box-photo {
    display: flex;
    justify-content: center;
    padding: 0 2.5rem var(--space-xl);
  }

  .box-image {
    max-width: 480px;
    border-radius: 8px;
    overflow: hidden;
  }

  .box-img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ===== BOXES ===== */
  .boxes {
    max-width: 600px;
    margin: 0 auto;
    padding: 0 2.5rem var(--space-2xl);
  }

  .boxes h2 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .box-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .box-card {
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: 1.5rem 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .box-card:hover {
    border-color: var(--terracotta);
    box-shadow: 0 4px 20px rgba(194, 112, 62, 0.08);
  }

  .box-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 400;
  }

  .box-meta {
    font-size: 0.75rem;
    color: var(--ink-muted);
  }

  /* ===== CONTACT ===== */
  .contact {
    max-width: 500px;
    margin: 0 auto;
    padding: var(--space-xl) 2.5rem var(--space-2xl);
    text-align: center;
  }

  .contact h2 {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .contact-body {
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.7;
    margin-bottom: var(--space-lg);
  }

  .contact-actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .contact-btn {
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--cream);
    background: var(--ink);
    padding: 0.85rem 2rem;
    border-radius: 100px;
    transition: all 0.2s;
  }

  .contact-btn:hover {
    background: var(--terracotta);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(194, 112, 62, 0.15);
  }

  .contact-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--ink-muted);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .contact-link:hover {
    color: var(--terracotta);
    border-color: var(--terracotta);
  }

  /* ===== FOOTER ===== */
  footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    padding: var(--space-xl) 2.5rem;
    border-top: 1px solid var(--rule-light);
  }

  footer p {
    font-size: 0.7rem;
    color: var(--ink-faint);
  }

  .footer-link {
    color: var(--ink-faint);
    border-bottom: 1px solid var(--rule-light);
    padding-bottom: 1px;
    transition: color 0.2s;
  }

  .footer-link:hover {
    color: var(--ink-muted);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 640px) {
    nav {
      padding: 1rem 1.5rem;
    }

    .nav-links {
      gap: 1.5rem;
    }

    .hero {
      padding: 7rem 1.5rem 3rem;
    }

    .hero-image {
      width: 200px;
      height: 200px;
    }

    .hero h1 {
      font-size: 1.8rem;
    }

    .menu,
    .boxes,
    .contact {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }

    .box-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }

    .story-image {
      width: 280px;
    }

    .box-image {
      max-width: 100%;
    }
  }
</style>
